# Copy to ".env" and fill in. Values are read by src/config.py at startup and
# only pre-fill the connection form -- you can still override them in the GUI.
BOSDYN_HOSTNAME=192.168.10.3
BOSDYN_USERNAME=student
BOSDYN_PASSWORD=

